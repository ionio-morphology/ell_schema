###  http://mmoon.org/deu/inventory/og/DerivedWord_Kauf
:DerivedWord_Kauf rdf:type owl:NamedIndividual ,
                           deu_schema:DerivedWord ;
                  mmoon:consistsOfAffix :ZeroMorph_01 ;
                  mmoon:consistsOfStem :Stem_kauf_1 ;
                  mmoon:derivationalRelation deu_schema:VerbalNoun ;
                  mmoon:hasRepresentation :Representation_Kauf ;
                  mmoon:hasWordclassAffiliation deu_schema:CommonNoun ;
                  mmoon:hasWordform :SyntheticWordform_Kauf_1 ,
                                    :SyntheticWordform_Kauf_2 ,
                                    :SyntheticWordform_Kauf_3 ,
                                    :SyntheticWordform_Kaufe ,
                                    :SyntheticWordform_Kaufes ,
                                    :SyntheticWordform_Kaufs ,
                                    :SyntheticWordform_Käufe_1 ,
                                    :SyntheticWordform_Käufe_2 ,
                                    :SyntheticWordform_Käufe_3 ,
                                    :SyntheticWordform_Käufen ;
                  mmoon:isDerivedFrom :Lexeme_kaufen ;
                  rdfs:label "Kauf"@de ,
                             """the buying,
the purchase"""@en .


