@prefix : <http://mmoon.org/deu/inventory/og/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix gold: <http://purl.org/linguistics/gold/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix mmoon: <http://mmoon.org/core/> .
@prefix deu_schema: <http://mmoon.org/deu/schema/og/> .
@base <http://mmoon.org/deu/inventory/og/> .

<http://mmoon.org/deu/inventory/og/> rdf:type owl:Ontology ;
                                      owl:imports mmoon: ,
                                                  deu_schema: .

#################################################################
#    Annotation properties
#################################################################

###  http://mmoon.org/core/consistsOfAffix
mmoon:consistsOfAffix rdf:type owl:AnnotationProperty .


###  http://mmoon.org/core/consistsOfMorpheme
mmoon:consistsOfMorpheme rdf:type owl:AnnotationProperty .


###  http://mmoon.org/core/consistsOfRoot
mmoon:consistsOfRoot rdf:type owl:AnnotationProperty .


###  http://mmoon.org/core/consistsOfStem
mmoon:consistsOfStem rdf:type owl:AnnotationProperty .


###  http://mmoon.org/core/correspondsToMorpheme
mmoon:correspondsToMorpheme rdf:type owl:AnnotationProperty .


###  http://mmoon.org/core/derivationalRelation
mmoon:derivationalRelation rdf:type owl:AnnotationProperty .


###  http://mmoon.org/core/hasMorphologicalRelationship
mmoon:hasMorphologicalRelationship rdf:type owl:AnnotationProperty .


###  http://mmoon.org/core/hasRepresentation
mmoon:hasRepresentation rdf:type owl:AnnotationProperty .


###  http://mmoon.org/core/hasWordclassAffiliation
mmoon:hasWordclassAffiliation rdf:type owl:AnnotationProperty .


###  http://mmoon.org/core/hasWordform
mmoon:hasWordform rdf:type owl:AnnotationProperty .


###  http://mmoon.org/core/isAllomorphTo
mmoon:isAllomorphTo rdf:type owl:AnnotationProperty .


###  http://mmoon.org/core/isDerivedFrom
mmoon:isDerivedFrom rdf:type owl:AnnotationProperty .


###  http://mmoon.org/core/isHomonymTo
mmoon:isHomonymTo rdf:type owl:AnnotationProperty .


###  http://mmoon.org/core/orthographicRepresentation
mmoon:orthographicRepresentation rdf:type owl:AnnotationProperty .


