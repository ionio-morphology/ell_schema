PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX mmoon: <http://mmoon.org/core/>
PREFIX ell_schema: <http://mmoon.org/ell/schema/omg/>
PREFIX : <http://mmoon.org/ell/inventory/omg/>

CONSTRUCT {
  ?stemIRI rdf:type mmoon:Stem ;
           mmoon:consistsOfStem ?stem ;
           ell_schema:consistsOfDerSuf  ?affix ;
           mmoon:orthographicRepresentation ?generatedForm ;
           ell_schema:isMappedTo ?stemPattern ;
    	   ell_schema:hasBase ?base	.
}
WHERE {
  ?stemPattern ell_schema:consistsOfDerSuf ?affix ;
               ell_schema:consistsOfStemPattern ?basePattern .

  ?basePattern ell_schema:isMappedTo ?stem .
  ?stem ell_schema:hasBase ?base ;  
        mmoon:orthographicRepresentation ?stemForm .
  ?affix mmoon:orthographicRepresentation ?affixForm ;
  

  BIND(CONCAT(?stemForm, ?affixForm) AS ?generatedForm)

  BIND(IRI(CONCAT(
    "http://mmoon.org/ell/inventory/omg/",
    STRAFTER(STR(?stem), "omg/"),
    "",
    STRAFTER(STR(?affix), "omg/")
  )) AS ?stemIRI)
}
