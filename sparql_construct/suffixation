PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX owl: <http://www.w3.org/2002/07/owl#>
PREFIX rdfs: <http://www.w3.org/2000/01/rdf-schema#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX mmoon: <http://mmoon.org/core/>
PREFIX ell_schema: <http://mmoon.org/ell/schema/omg/>
PREFIX : <http://mmoon.org/ell/inventory/omg/>


CONSTRUCT {
  ?sourceWord ell_schema:generates ?targetWord .

  ?sourceWord mmoon:orthographicRepresentation ?sourceOrth.
  ?targetWord mmoon:orthographicRepresentation ?targetOrth.
}
WHERE {
  ?drvPattern ell_schema:hasSourceWP ?sourceWP ;
              ell_schema:hasTargetWP ?targetWP .

  ?sourceWord ell_schema:isMappedTo ?sourceWP ;
              ell_schema:hasBase ?base ;
              mmoon:orthographicRepresentation ?sourceOrth .

  ?targetWord ell_schema:isMappedTo ?targetWP ;
              ell_schema:hasBase ?base ;
              mmoon:orthographicRepresentation ?targetOrth .

  FILTER(?sourceWord != ?targetWord)
}
