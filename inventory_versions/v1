#################################################################
#    Object Properties
#################################################################

###  http://mmoon.org/core/associatedToLanguage
mmoon:associatedToLanguage rdf:type owl:ObjectProperty ;
                           mmoon:definition "States that a morpheme inventory, morph or word is associated to a specific langauge."@en ;
                           rdfs:label "associated to language"@en .


###  http://mmoon.org/core/attachedTo
mmoon:attachedTo rdf:type owl:ObjectProperty ;
                 rdfs:domain mmoon:Affix ;
                 rdfs:range [ rdf:type owl:Class ;
                              owl:unionOf ( mmoon:Root
                                            mmoon:Stem
                                          )
                            ] ;
                 mmoon:definition "States that an affix is attached to some stem or root."@en ;
                 rdfs:label "attached to"@en .


###  http://mmoon.org/core/attachedToRoot
mmoon:attachedToRoot rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf mmoon:attachedTo ;
                     rdfs:domain mmoon:Affix ;
                     rdfs:range mmoon:Root ;
                     mmoon:definition "States that an affix is attached to some root."@en ;
                     rdfs:label "attached to root"@en .


###  http://mmoon.org/core/attachedToStem
mmoon:attachedToStem rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf mmoon:attachedTo ;
                     rdfs:domain mmoon:Affix ;
                     rdfs:range mmoon:Stem ;
                     mmoon:definition "States that an affix is attached to some stem."@en ;
                     rdfs:label "attached to stem"@en .


###  http://mmoon.org/core/belongsTo
mmoon:belongsTo rdf:type owl:ObjectProperty ;
                rdfs:subPropertyOf owl:topObjectProperty ;
                owl:inverseOf mmoon:consistsOfMorph ;
                rdfs:domain mmoon:Morph ;
                rdfs:range [ rdf:type owl:Class ;
                             owl:unionOf ( mmoon:Root
                                           mmoon:Stem
                                           mmoon:Word
                                         )
                           ] ;
                mmoon:definition "States that a morph belongs to some word, stem or root."@en ;
                rdfs:label "belongs to"@en .


###  http://mmoon.org/core/belongsToLexicalEntry
mmoon:belongsToLexicalEntry rdf:type owl:ObjectProperty ;
                            owl:inverseOf mmoon:hasWordform ;
                            rdfs:domain mmoon:Wordform ;
                            rdfs:range mmoon:LexicalEntry ;
                            mmoon:definition "States that a word-form resource belongs to a lexical entry resource."@en ;
                            rdfs:label "belongs to lexical entry"@en .


###  http://mmoon.org/core/compoundingRelation
mmoon:compoundingRelation rdf:type owl:ObjectProperty ;
                          rdfs:subPropertyOf mmoon:hasMorphologicalRelationship ;
                          rdfs:domain mmoon:CompoundWord ;
                          rdfs:range mmoon:Compounding ;
                          mmoon:definition "States which kind of compounding relationship applies to a compound word."@en ;
                          rdfs:label "compounding relation"@en .


###  http://mmoon.org/core/consistsOfAffix
mmoon:consistsOfAffix rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf mmoon:consistsOfMorph ;
                      rdfs:range mmoon:Affix ;
                      mmoon:definition "States that a word, stem or root consists of some affix."@en ;
                      rdfs:label "consists of affix"@en .


###  http://mmoon.org/core/consistsOfMorph
mmoon:consistsOfMorph rdf:type owl:ObjectProperty ;
                      rdfs:range mmoon:Morph ;
                      mmoon:definition "States that a word, stem or root consists of some morph."@en ;
                      rdfs:label "consists of morph"@en .


###  http://mmoon.org/core/consistsOfRoot
mmoon:consistsOfRoot rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf mmoon:consistsOfMorph ;
                     rdfs:range mmoon:Root ;
                     mmoon:definition "States that a word, stem or root consists of some root."@en ;
                     rdfs:label "consists of root"@en .


###  http://mmoon.org/core/consistsOfStem
mmoon:consistsOfStem rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf mmoon:consistsOfMorph ;
                     mmoon:definition "States that a word or stem consists of some stem."@en ;
                     rdfs:label "consists of stem"@en .


###  http://mmoon.org/core/consistsOfWord
mmoon:consistsOfWord rdf:type owl:ObjectProperty ;
                     rdfs:range mmoon:Word ;
                     mmoon:definition "States that an analytic word-form (such as \"more big\" being the comparative form of the adjective \"big\") or compound word consists of other word resources."@en ;
                     rdfs:label "consists of word"@en .


###  http://mmoon.org/core/contextualInflectionalMeaning
mmoon:contextualInflectionalMeaning rdf:type owl:ObjectProperty ;
                                    rdfs:subPropertyOf mmoon:inflectionalMeaning ;
                                    rdfs:range mmoon:LinguisticCategory ;
                                    mmoon:definition """States that the meaning \"comprises values (of linguistic categories) which are assigned [...] because of the syntactic context in which it (the word or morph) appears\".
[Haspelmath and Sims: Understanding morphology. 2002:100]"""@en ;
                                    mmoon:example "\"klein-e Frau\" 'small-NOM.SG.F woman.NOM.SG.F' - contextual inflection (noun agreement marking)"@de ;
                                    rdfs:label "contextual inflectional meaning"@en .


###  http://mmoon.org/core/correspondsToMorpheme
mmoon:correspondsToMorpheme rdf:type owl:ObjectProperty ;
                            owl:inverseOf mmoon:hasRealization ;
                            rdfs:domain mmoon:Morph ;
                            rdfs:range mmoon:Morpheme ;
                            mmoon:definition "States that a morph corresponds to a morpheme."@en ;
                            rdfs:label "corresponds to morpheme"@en .


###  http://mmoon.org/core/derivationalMeaning
mmoon:derivationalMeaning rdf:type owl:ObjectProperty ;
                          rdfs:subPropertyOf mmoon:hasMeaning ;
                          rdfs:range mmoon:DerivationalMeaning ;
                          owl:propertyChainAxiom ( mmoon:isAllomorphTo
                                                   mmoon:derivationalMeaning
                                                 ) ,
                                                 ( ell_schema:consistsOfDerPref
                                                   mmoon:derivationalMeaning
                                                 ) ,
                                                 ( ell_schema:consistsOfDerSuf
                                                   mmoon:derivationalMeaning
                                                 ) ,
                                                 ( ell_schema:consistsOfMultiMorph
                                                   mmoon:derivationalMeaning
                                                 ) ,
                                                 ( ell_schema:consistsOfStemOfAWord
                                                   mmoon:derivationalMeaning
                                                 ) ;
                          mmoon:definition "States that a morph, morpheme or word resource has some derivational meaning."@en ;
                          rdfs:label "derivational meaning"@en .


###  http://mmoon.org/core/derivationalRelation
mmoon:derivationalRelation rdf:type owl:ObjectProperty ;
                           rdfs:subPropertyOf mmoon:hasMorphologicalRelationship ;
                           rdfs:domain mmoon:DerivedWord ;
                           rdfs:range mmoon:Derivation ;
                           mmoon:definition "States which kind of derivational  relationship applies to a derived word."@en ;
                           mmoon:usageNote "This property is also used to state that a simple lexeme which cannot be further segmented with respect to word-formation has the morphological relationship mmoon:NoWordFormation."@en ;
                           rdfs:label "derivational relation"@en .


###  http://mmoon.org/core/forLanguage
mmoon:forLanguage rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf mmoon:associatedToLanguage ;
                  rdfs:domain mmoon:MorphemeInventory ;
                  mmoon:definition "States that a MMoOn morpheme inventory is specified for a certain language."@en ;
                  rdfs:label "for language"@en .


###  http://mmoon.org/core/grammaticalMeaning
mmoon:grammaticalMeaning rdf:type owl:ObjectProperty ;
                         rdfs:subPropertyOf mmoon:hasMeaning ;
                         owl:propertyChainAxiom ( mmoon:hasRepresentation
                                                  mmoon:grammaticalMeaning
                                                ) ,
                                                ( mmoon:isAllomorphTo
                                                  mmoon:grammaticalMeaning
                                                ) ,
                                                ( ell_schema:consistsOfDerSuf
                                                  mmoon:grammaticalMeaning
                                                ) ,
                                                ( ell_schema:consistsOfInfSuf
                                                  mmoon:grammaticalMeaning
                                                ) ,
                                                ( ell_schema:consistsOfMultiMorph
                                                  mmoon:grammaticalMeaning
                                                ) ,
                                                ( ell_schema:consistsOfStemOfAPrefStem
                                                  mmoon:grammaticalMeaning
                                                ) ,
                                                ( ell_schema:consistsOfStemOfAWord
                                                  mmoon:grammaticalMeaning
                                                ) ,
                                                ( ell_schema:consistsOfStemOfAWordPattern
                                                  mmoon:grammaticalMeaning
                                                ) ;
                         mmoon:definition "States that a morph, morpheme or word resource has some grammatical meaning."@en ;
                         rdfs:label "grammatical meaning"@en .


###  http://mmoon.org/core/hasAbstractIdentity
mmoon:hasAbstractIdentity rdf:type owl:ObjectProperty ;
                          rdfs:range mmoon:MorphemicGloss ;
                          mmoon:definition "States that a morpheme or meaning resource is assigned to one (ore more) morphemic gloss(es)."@en ;
                          rdfs:label "has abstract identity"@en .


###  http://mmoon.org/core/hasMeaning
mmoon:hasMeaning rdf:type owl:ObjectProperty ;
                 rdfs:range mmoon:Meaning ;
                 mmoon:definition "States that a morph, morpheme or word resource has some meaning."@en ;
                 rdfs:label "has meaning"@en .


###  http://mmoon.org/core/hasMorphemicEntry
mmoon:hasMorphemicEntry rdf:type owl:ObjectProperty ;
                        rdfs:domain mmoon:MorphemeInventory ;
                        rdfs:range [ rdf:type owl:Class ;
                                     owl:unionOf ( mmoon:Morph
                                                   mmoon:Morpheme
                                                 )
                                   ] ;
                        mmoon:definition "States that a morpheme inventory resource has morphemes as morphemic entries, thus building the intension of the morpheme inventory."@en ;
                        rdfs:label "has morphemic entry"@en .


###  http://mmoon.org/core/hasMorphologicalRelationship
mmoon:hasMorphologicalRelationship rdf:type owl:ObjectProperty ;
                                   rdfs:domain mmoon:Word ;
                                   rdfs:range mmoon:MorphologicalRelationship ;
                                   mmoon:definition "Specifies the morphological relationship of a word."@en ;
                                   rdfs:label "has morphological relationship"@en .


###  http://mmoon.org/core/hasRealization
mmoon:hasRealization rdf:type owl:ObjectProperty ;
                     rdfs:domain mmoon:Morpheme ;
                     rdfs:range mmoon:Morph ;
                     mmoon:definition "States that a morpheme is realized by a morph."@en ;
                     rdfs:label "has realization"@en .


###  http://mmoon.org/core/hasRepresentation
mmoon:hasRepresentation rdf:type owl:ObjectProperty ;
                        owl:inverseOf ell_schema:isRepresentationOf ;
                        rdfs:range mmoon:Representation ;
                        mmoon:definition "States that a word or morph has some linguistic representation."@en ;
                        rdfs:label "has representation"@en .


###  http://mmoon.org/core/hasSense
mmoon:hasSense rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf mmoon:hasMeaning ;
               rdfs:range mmoon:Sense ;
               owl:propertyChainAxiom ( ell_schema:consistsOfStemOfAWord
                                        mmoon:hasSense
                                      ) ;
               mmoon:definition "States that a morph, morpheme or word resource has some sense."@en ;
               rdfs:label "has sense"@en .


###  http://mmoon.org/core/hasWordclassAffiliation
mmoon:hasWordclassAffiliation rdf:type owl:ObjectProperty ;
                              rdfs:subPropertyOf mmoon:hasMeaning ;
                              rdfs:range mmoon:WordclassAffiliation ;
                              mmoon:definition "States that a morph, morpheme or word resource has a wordclass affiliation."@en ;
                              rdfs:label "has wordclass affiliation"@en .


###  http://mmoon.org/core/hasWordform
mmoon:hasWordform rdf:type owl:ObjectProperty ;
                  rdfs:domain mmoon:LexicalEntry ;
                  rdfs:range mmoon:Wordform ;
                  mmoon:definition "States that a lexical entry resource has an associated word-form resource."@en ;
                  rdfs:label "has wordform"@en .


###  http://mmoon.org/core/inflectionalMeaning
mmoon:inflectionalMeaning rdf:type owl:ObjectProperty ;
                          rdfs:subPropertyOf mmoon:hasMeaning ;
                          rdfs:range mmoon:LinguisticCategory ;
                          mmoon:definition "States that a morph, morpheme or word resource has some inflectional meaning."@en ;
                          rdfs:label "inflectional meaning"@en .


###  http://mmoon.org/core/inflectionalRelation
mmoon:inflectionalRelation rdf:type owl:ObjectProperty ;
                           rdfs:subPropertyOf mmoon:hasMorphologicalRelationship ;
                           rdfs:domain mmoon:Word ;
                           rdfs:range mmoon:Inflection ;
                           mmoon:definition "States which kind of inflectional relationship applies to a word."@en ;
                           rdfs:label "inflectional relation"@en .


###  http://mmoon.org/core/inherentInflectionalMeaning
mmoon:inherentInflectionalMeaning rdf:type owl:ObjectProperty ;
                                  rdfs:subPropertyOf mmoon:inflectionalMeaning ;
                                  rdfs:range mmoon:LinguisticCategory ;
                                  mmoon:definition """States that the meaning \"comprises features (= linguistic categories) that are relevant to the syntax but convey a certain amount of independent information\". E.g. the tense/aspect values for verbs or the number or gender values for nouns.
[Haspelmath and Sims: Understanding morphology. 2002:100]"""@de ;
                                  mmoon:example "\"klein-er-e Frau\" 'small-COMPR-NOM.SG.F woman.NOM.SG.F' - inherent inflection for degree of comparison"@de ;
                                  rdfs:label "inherent inflectionalm eaning"@en .


###  http://mmoon.org/core/isAllomorphTo
mmoon:isAllomorphTo rdf:type owl:ObjectProperty ;
                    owl:inverseOf mmoon:isAllomorphTo ;
                    rdf:type owl:SymmetricProperty ;
                    rdfs:range [ rdf:type owl:Class ;
                                 owl:unionOf ( mmoon:Morph
                                               mmoon:Representation
                                             )
                               ] ;
                    mmoon:definition "States that a morph is an allomorph to another morph which are both realizations of the same morpheme and which occur in complementary or free distribution."@en ;
                    mmoon:externalDefinitionDesc "An allomorph is one of two or more complementary morphs which manifest a morpheme in its different phonological or morphological environments. [http://www-01.sil.org/linguistics/GlossaryOflinguisticTerms/WhatIsAnAllomorph.htm]"@en ;
                    rdfs:label "is allomorph to"@en .


###  http://mmoon.org/core/isComposedOf
mmoon:isComposedOf rdf:type owl:ObjectProperty ;
                   rdfs:domain mmoon:CompoundWord ;
                   rdfs:range [ rdf:type owl:Class ;
                                owl:unionOf ( mmoon:GrammaticalWord
                                              mmoon:Lexeme
                                            )
                              ] ;
                   mmoon:definition "States that a compound word is composed of a lexical entry resource."@en ;
                   rdfs:label "is composed of"@en .


###  http://mmoon.org/core/isDerivedFrom
mmoon:isDerivedFrom rdf:type owl:ObjectProperty ;
                    owl:inverseOf ell_schema:generates ;
                    rdfs:domain mmoon:DerivedWord ;
                    rdfs:range [ rdf:type owl:Class ;
                                 owl:unionOf ( mmoon:GrammaticalWord
                                               mmoon:LexicalEntry
                                             )
                               ] ;
                    mmoon:definition "States that a derived word is derived from a lexical entry resource."@en ;
                    rdfs:label "is derived from"@en .


###  http://mmoon.org/core/isHomonymTo
mmoon:isHomonymTo rdf:type owl:ObjectProperty ;
                  owl:inverseOf mmoon:isHomonymTo ;
                  rdf:type owl:SymmetricProperty ;
                  rdfs:domain mmoon:Morph ;
                  rdfs:range mmoon:Morph ;
                  mmoon:definition "States that a morph is homonym to another morph, i.e. although sharing the same orthographic and/or morphemic representation both morphs encode different meanings and thus realize different morphemes."@en ;
                  rdfs:label "is homonym to"@en .


###  http://mmoon.org/core/partOfLanguage
mmoon:partOfLanguage rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf mmoon:associatedToLanguage ;
                     mmoon:definition "States that a morph or word resources is a linguistic entity as part of a certain language."@en ;
                     rdfs:label "part of language"@en .


###  http://mmoon.org/ell/schema/omg/belongsToAllomParadigm
ell_schema:belongsToAllomParadigm rdf:type owl:ObjectProperty ;
                                  owl:inverseOf ell_schema:hasStem ;
                                  rdfs:range ell_schema:AllomorphyParadigm ;
                                  owl:propertyChainAxiom ( mmoon:isAllomorphTo
                                                           ell_schema:isMappedTo
                                                           ell_schema:belongsToAllomParadigm
                                                         ) .


