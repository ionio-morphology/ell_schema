###  http://mmoon.org/core/FactitiveVerb
mmoon:FactitiveVerb rdf:type owl:Class ;
                    rdfs:subClassOf mmoon:DeadjectivalVerb ;
                    owl:disjointWith mmoon:FemaleNoun ,
                                     mmoon:InstrumentNoun ,
                                     mmoon:MaterialAdjectivizer ,
                                     mmoon:NominalAdverb ,
                                     mmoon:NominalVerb ,
                                     mmoon:NounAdjective ,
                                     mmoon:PossessiveAdjective ,
                                     mmoon:VerbalAdjective ,
                                     mmoon:VerbalNoun ,
                                     ell_schema:Affixation ,
                                     ell_schema:Prefixation ,
                                     ell_schema:Suffixation ;
                    mmoon:definition "A verb which is derived from an adjective stem denoting causation."@en ;
                    mmoon:example """\"black\"(Adj) --> \"blacken\"(Vtr.).
 [Christian Lehmann, under \"factitive verb\" at http://linguistik.uni-regensburg.de:8080/lido/Lido]"""@en ,
                                  """\"tot\"(Adj) 'dead' --> \"töten\"(V) 'to kill'.
[Christian Lehmann, under \"factitive verb\" at http://linguistik.uni-regensburg.de:8080/lido/Lido]"""@de ;
                    mmoon:externalDefinitionDesc """A factitive verb is a causative verb based on an adjective (or a stative intransitive verb).

Delimitation and History:
While there may be a subordinate agent in a causative construction, there may be none in a factitive one. This has sometimes been a reason for not subsuming factitive under causative.
[Christian Lehmann, under \"factitive verb\" at http://linguistik.uni-regensburg.de:8080/lido/Lido]"""@en ;
                    rdfs:label "Factitive Verb"@en .


